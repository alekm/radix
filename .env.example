# RADIX configuration. Copy to .env and edit. Uncommented lines are required;
# commented lines show the default and are optional overrides.
#
# DB_HOST / DB_NAME / DB_USER are fixed in docker-compose.yml (the postgres
# service); only the password flows through here.

# ── Required ─────────────────────────────────────────────────────────────────
DB_PASSWORD=changeme
RADIUS_SECRET=testing123

# Admin UI HTTP Basic auth. The web UI refuses to serve if ADMIN_PASSWORD is unset.
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# ── Display / locale ─────────────────────────────────────────────────────────
# Timezone for displayed timestamps (any IANA name). Applies to all services.
TZ=America/Kentucky/Louisville

# Shown on the web UI Settings page so you can configure your APs (informational).
#RADIUS_HOST=192.168.1.1
#RADIUS_PORT=1812

# ── RADIUS / auth path (radius service) ──────────────────────────────────────
#PMK_CACHE_TTL=86400          # Tier-1 PMK cache lifetime, seconds
#DB_POOL_MAX=16               # max pooled DB connections
#RADIX_DEBUG=0                # 1/true: log full request + reply attributes (verbose)

# How to hand the matched PMK back to a Ruckus AP:
#   mppe = MS-MPPE-Recv-Key  (Unleashed / ZoneDirector)   [default]
#   vsa  = Ruckus-DPSK VSA   (SmartZone)
#RUCKUS_DPSK_REPLY=mppe

# Tier-3 (new-device brute-force scan) rate limiting.
#RADIX_TIER3_RATE=50           # global scans/sec (token-bucket refill)
#RADIX_TIER3_BURST=100         # token-bucket capacity
#RADIX_TIER3_MAX_FAILURES=10   # per-MAC failures before cooldown
#RADIX_TIER3_FAIL_WINDOW=60    # seconds the failure count accumulates over
#RADIX_TIER3_COOLDOWN=120      # seconds a MAC is blocked after tripping
#RADIX_TIER3_MAX_TRACKED=10000 # cap on tracked MACs (memory bound)

# ── Retention & analytics (web service) ──────────────────────────────────────
#RETENTION_DAYS=90             # purge auth_log/acct_sessions/metrics older than this; 0 disables
#RETENTION_INTERVAL_HOURS=24   # how often the retention sweep runs
#ANALYTICS_INTERVAL_SECONDS=300 # dashboard sampling + recompute cadence
#ANALYTICS_WINDOW_DAYS=7       # time window the dashboard charts cover

# A session counts as "active" only if updated within this window (minutes).
# Requires interim accounting on the AP; set >= 2x the interim interval.
# 0 disables the staleness check (active = any open session).
#SESSION_STALE_MINUTES=30
